# Hjerterum frontend — copy to .env.local and fill in values

# Required (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only (webhooks, Stripe Connect)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Client (Stripe Checkout — optional until payments go live)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional monitoring (Phase 7)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# App URL for Stripe redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Test only: skip BankID/Signicat signing (staging — never in production)
# BANKID_AUTO_ACCEPT=true
# NEXT_PUBLIC_BANKID_AUTO_ACCEPT=true
