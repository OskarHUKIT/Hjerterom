{
  "name": "boly-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:mobile": "node build-mobile.js",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "analyze": "cross-env ANALYZE=true next build",
    "format": "prettier --write \"app/dev/**/*.{ts,tsx}\" \"eslint.config.mjs\" \"tailwind.config.js\" \"postcss.config.js\"",
    "format:check": "prettier --check \"app/dev/**/*.{ts,tsx}\" \"eslint.config.mjs\" \"tailwind.config.js\" \"postcss.config.js\"",
    "format:all": "prettier --write .",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "mobile:build": "npm run build:mobile && npm run cap:sync",
    "mobile:ios": "npm run mobile:build && npm run cap:open:ios",
    "mobile:android": "npm run mobile:build && npm run cap:open:android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-query": "^5.99.0",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "next": "^16.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@next/bundle-analyzer": "^16.2.3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0"
  }
}
